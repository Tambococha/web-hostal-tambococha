---
// src/components/NavBar.astro
import { Image } from 'astro:assets';
// Asegúrate de colocar tu PNG en esta ruta exacta:
import logoHotel from '../assets/logos/logo-tambococha.png'; 
---
<header class="fixed top-0 left-0 right-0 z-50 glass-nav border-b border-primary/10">
    <div class="max-w-[1440px] w-full mx-auto px-4 md:px-6 lg:px-10 h-20 md:h-24 flex items-center justify-between gap-2">
        
        <!-- Logo (Left) -->
        <div class="flex-1 flex justify-start min-w-0">
            <a href="/" class="flex items-center gap-2 md:gap-3 group w-max max-w-full">
                
                <!-- TRUCO VIBE CODING: Usamos la etiqueta img clásica y llamamos al .src -->
                <img 
                    src={logoHotel.src} 
                    alt="Logo Hostal Tambococha" 
                    class="w-8 h-8 md:w-10 md:h-10 lg:w-14 lg:h-14 object-contain group-hover:scale-110 transition-transform shrink-0"
                />
                
                <div class="flex flex-col leading-tight min-w-0">
                    <span class="text-sm md:text-xl font-extrabold tracking-tight text-earth font-serif truncate">Hostal Tambococha</span>
                    <span class="text-[8px] md:text-[10px] font-bold uppercase tracking-[0.1em] md:tracking-[0.2em] text-earth/60 font-sans truncate">Catacocha - Ecuador</span>
                </div>
            </a>
        </div>

        <!-- Desktop Navigation Links (Center) -->
        <nav class="hidden lg:flex flex-none items-center justify-center gap-3 xl:gap-8">
            <a class="text-[10px] xl:text-xs font-bold hover:text-primary transition-colors uppercase tracking-widest whitespace-nowrap" href="/">Hostal</a>
            <a class="text-[10px] xl:text-xs font-bold hover:text-primary transition-colors uppercase tracking-widest whitespace-nowrap" href="/actividades">Actividades</a>
            <a class="text-[10px] xl:text-xs font-bold hover:text-primary transition-colors uppercase tracking-widest whitespace-nowrap" href="/habitaciones">Habitaciones</a>
            <a class="text-[10px] xl:text-xs font-bold hover:text-primary transition-colors uppercase tracking-widest whitespace-nowrap" href="/ubicacion">Ubicación</a>
            <a class="text-[10px] xl:text-xs font-bold hover:text-primary transition-colors uppercase tracking-widest whitespace-nowrap" href="/contacto">Contacto</a>
        </nav>

        <!-- Desktop Actions (Right) -->
        <div class="hidden md:flex flex-1 items-center justify-end gap-2 xl:gap-4">
            <!-- Line between Links and Social Icons -->
            <div class="h-6 w-px bg-earth/15 hidden lg:block mx-1"></div>
            
            <div class="flex gap-2">
                <a class="w-9 h-9 rounded-full flex items-center justify-center bg-earth/5 hover:bg-primary hover:text-white text-earth transition-all shadow-sm" href="https://www.facebook.com/hostaltambococha" target="_blank" aria-label="Facebook">
                    <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"></path></svg>
                </a>
                <a class="w-9 h-9 rounded-full flex items-center justify-center bg-earth/5 hover:bg-primary hover:text-white text-earth transition-all shadow-sm" href="https://www.instagram.com/hoteltambococha/" target="_blank" aria-label="Instagram">
                    <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.791-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.209-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"></path></svg>
                </a>
            </div>
            <!-- Line between Social Icons and CTA -->
            <div class="h-6 w-px bg-earth/15 mx-1"></div>
            <!-- NOTA: Más adelante conectaremos este botón al flujo de reservas o WhatsApp -->
            <a class="bg-sage hover:bg-earth text-white px-4 lg:px-6 xl:px-8 py-2 md:py-3 rounded-lg font-bold text-[10px] lg:text-xs uppercase tracking-widest transition-all shadow-md whitespace-nowrap" href="/habitaciones">RESERVAR AHORA</a>
        </div>

        <!-- Mobile Menu Button -->
        <button id="mobile-menu-btn" class="lg:hidden w-10 h-10 flex flex-col items-center justify-center gap-1.5 focus:outline-none text-earth hover:text-primary transition-colors ml-auto flex-shrink-0" aria-label="Menú Móvil">
            <span class="line-1 block w-6 h-[2px] bg-current rounded-full transition-all duration-300 ease-in-out origin-center"></span>
            <span class="line-2 block w-6 h-[2px] bg-current rounded-full transition-all duration-300 ease-in-out origin-center"></span>
            <span class="line-3 block w-6 h-[2px] bg-current rounded-full transition-all duration-300 ease-in-out origin-center"></span>
        </button>
    </div>

    <!-- Mobile Navigation -->
    <div id="mobile-menu" class="lg:hidden absolute top-20 md:top-24 left-0 right-0 glass-nav border-b border-primary/10 shadow-2xl overflow-hidden transition-all duration-300 ease-in-out transform -translate-y-4 opacity-0 pointer-events-none invisible">
        <nav class="flex flex-col px-4 md:px-6 py-6 pb-8 gap-5 h-[calc(100vh-80px)] md:h-[calc(100vh-96px)] overflow-y-auto">
            <a class="text-lg font-bold hover:text-primary transition-colors uppercase tracking-widest border-b border-earth/10 pb-4" href="/">Inicio</a>
            <a class="text-lg font-bold hover:text-primary transition-colors uppercase tracking-widest border-b border-earth/10 pb-4" href="/actividades">Actividades</a>
            <div class="flex flex-col border-b border-earth/10 pb-4 gap-3">
                <a class="text-lg font-bold hover:text-primary transition-colors uppercase tracking-widest" href="/habitaciones">Habitaciones</a>
                <!-- Sub-categorías de Habitaciones -->
                <div class="flex flex-col pl-6 gap-3 mt-1">
                    <a class="text-sm font-semibold hover:text-primary transition-colors uppercase tracking-wider text-earth/80" href="/habitacionsingle">- Simple</a>
                    <a class="text-sm font-semibold hover:text-primary transition-colors uppercase tracking-wider text-earth/80" href="/habitacionmatrimonial">- Matrimonial</a>
                    <a class="text-sm font-semibold hover:text-primary transition-colors uppercase tracking-wider text-earth/80" href="/habitaciondoble">- Doble/Triple</a>
                    <a class="text-sm font-semibold hover:text-primary transition-colors uppercase tracking-wider text-earth/80" href="/habitacionfamiliar">- Familiar</a>
                </div>
            </div>
            <a class="text-lg font-bold hover:text-primary transition-colors uppercase tracking-widest border-b border-earth/10 pb-4" href="/ubicacion">Ubicación</a>
            <a class="text-lg font-bold hover:text-primary transition-colors uppercase tracking-widest border-b border-earth/10 pb-4" href="/contacto">Contacto</a>
            <div class="mt-4 mb-4">
                <a class="bg-sage hover:bg-sage/90 block text-center text-white px-6 py-4 rounded-xl font-bold text-sm uppercase tracking-widest transition-all" href="/habitaciones">RESERVAR AHORA</a>
            </div>
            <div class="flex gap-4 justify-center pb-4">
                <!-- Redes sociales móvil -->
                <a class="w-12 h-12 rounded-full flex items-center justify-center bg-earth/5 text-earth hover:bg-primary/10 hover:text-primary transition-all shadow-sm" href="https://www.facebook.com/hostaltambococha" target="_blank" aria-label="Facebook">
                    <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"></path></svg>
                </a>
                <a class="w-12 h-12 rounded-full flex items-center justify-center bg-earth/5 text-earth hover:bg-primary/10 hover:text-primary transition-all shadow-sm" href="https://www.instagram.com/hoteltambococha/" target="_blank" aria-label="Instagram">
                    <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.791-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.209-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"></path></svg>
                </a>
            </div>
            <!-- Reglamento Interno Móvil -->
            <div class="text-center mt-2 pb-6 border-t border-earth/5 pt-4">
                <a href="/reglamento" class="inline-block text-[11px] font-bold uppercase tracking-[0.2em] text-earth/40 hover:text-primary transition-colors">
                    Reglamento Interno
                </a>
            </div>
        </nav>
    </div>
</header>

<script>
    function setupMobileMenu() {
        const btn = document.getElementById('mobile-menu-btn');
        const menu = document.getElementById('mobile-menu');
        
        // Removemos event listeners antiguos si los hay (importante para ViewTransitions)
        if (!btn || !menu) return;

        // Clonamos el botón para evitar que se acumulen event listeners con Astro ViewTransitions
        const newBtn = btn.cloneNode(true) as HTMLElement;
        btn.parentNode?.replaceChild(newBtn, btn);

        newBtn.addEventListener('click', () => {
            const isClosed = menu.classList.contains('invisible');
            
            const line1 = newBtn.querySelector('.line-1');
            const line2 = newBtn.querySelector('.line-2');
            const line3 = newBtn.querySelector('.line-3');

            if (isClosed) {
                // Open it smoothly
                menu.classList.remove('invisible', 'opacity-0', 'pointer-events-none', '-translate-y-4');
                menu.classList.add('visible', 'opacity-100', 'pointer-events-auto', 'translate-y-0');
                
                if (line1 && line2 && line3) {
                    line1.classList.add('translate-y-2', 'rotate-45');
                    line2.classList.add('opacity-0');
                    line3.classList.add('-translate-y-2', '-rotate-45');
                }
            } else {
                // Close it smoothly
                menu.classList.remove('visible', 'opacity-100', 'pointer-events-auto', 'translate-y-0');
                menu.classList.add('invisible', 'opacity-0', 'pointer-events-none', '-translate-y-4');
                
                if (line1 && line2 && line3) {
                    line1.classList.remove('translate-y-2', 'rotate-45');
                    line2.classList.remove('opacity-0');
                    line3.classList.remove('-translate-y-2', '-rotate-45');
                }
            }
        });
    }

    // Inicializar en primera carga
    setupMobileMenu();
</script>
