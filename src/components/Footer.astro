---
// Footer.astro
import logoHotel from '../assets/logos/logo-tambococha.png';
---
<footer class="bg-earth text-white/80 py-12 md:py-16 lg:py-20 px-4 md:px-6 lg:px-10">
    <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 md:gap-10 lg:gap-12 mb-12 lg:mb-16">
            <div class="space-y-4 md:space-y-6">
                <div class="flex items-center gap-3">
                    <img src={logoHotel.src} alt="Logo Hotel Tambococha" class="w-12 h-12 object-contain bg-white rounded-full p-1 drop-shadow-lg" />
                    <div class="flex flex-col leading-tight">
                        <span class="text-xl font-extrabold tracking-tight text-white font-serif">Hotel Tambococha</span>
                        <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-white/60 font-sans">Catacocha - Ecuador</span>
                    </div>
                </div>
                <p class="text-sm leading-relaxed">
                    Refugio de paz y tradición en el corazón de los Andes. Ofrecemos una experiencia única donde la historia de Catacocha se une a la comodidad moderna.
                </p>
            </div>
            
            <div>
                <h5 class="text-white font-bold mb-4 md:mb-6 text-sm uppercase tracking-widest font-serif">Explorar</h5>
                <ul class="space-y-4 text-sm">
                    <li><a class="hover:text-primary transition-colors" href="/habitaciones">Habitaciones</a></li>
                    <li><a class="hover:text-primary transition-colors" href="/">Nuestro Hotel</a></li>
                    <li><a class="hover:text-primary transition-colors" href="/actividades">Actividades</a></li>
                    <li><a class="hover:text-primary transition-colors" href="/ubicacion">Ubicación</a></li>
                    <li><a class="hover:text-primary transition-colors" href="/contacto">Contacto</a></li>
                </ul>
            </div>
            
            <div>
                <h5 class="text-white font-bold mb-4 md:mb-6 text-sm uppercase tracking-widest font-serif">Contacto</h5>
                <ul class="space-y-4 text-sm">
                    <li class="flex gap-3">
                        <span class="material-symbols-outlined text-primary text-xl">location_on</span>
                        <span>25 de Junio y Lauro Guerrero, Catacocha, Loja, Ecuador</span>
                    </li>
                    <li class="flex gap-3">
                        <span class="material-symbols-outlined text-primary text-xl">call</span>
                        <span>Whatsapp: +593 9 8526 5183 // +593 9 9087 0767</span>
                    </li>
                    <li class="flex gap-3">
                        <span class="material-symbols-outlined text-primary text-xl">mail</span>
                        <span>hoteltambococha@gmail.com</span>
                    </li>
                </ul>
            </div>
            
            <div>
                <h5 class="text-white font-bold mb-4 md:mb-6 text-sm uppercase tracking-widest font-serif">Síguenos</h5>
                <div class="flex gap-4">
                    <a class="w-10 h-10 rounded-full border border-white/20 flex items-center justify-center hover:bg-primary hover:border-primary transition-all text-white" href="https://www.facebook.com/hostaltambococha" target="_blank" aria-label="Facebook">
                        <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"></path></svg>
                    </a>
                    <a class="w-10 h-10 rounded-full border border-white/20 flex items-center justify-center hover:bg-primary hover:border-primary transition-all text-white" href="https://www.instagram.com/hoteltambococha/" target="_blank" aria-label="Instagram">
                        <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.791-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.209-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"></path></svg>
                    </a>
                </div>
            </div>
        </div>
        
        <div class="pt-6 md:pt-8 border-t border-white/10 flex flex-col md:flex-row justify-between items-center text-center md:text-left gap-4 text-[10px] md:text-xs font-medium uppercase tracking-widest text-white/40">
            <p class="leading-relaxed">© {new Date().getFullYear()} Hotel Tambococha. Todos los derechos reservados.</p>
            <div class="flex gap-6 md:gap-8">
                <a class="hover:text-white transition-colors" href="#">Privacidad</a>
                <a class="hover:text-white transition-colors" href="#">Términos</a>
            </div>
        </div>
    </div>
</footer>
