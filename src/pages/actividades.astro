---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';

import miradorShiriculapoImg from '../assets/photos/mirador-shiriculapo.jpg';
import catacochaSenderismoImg from '../assets/photos/catacocha-senderismo.jpg';
import reservaPisacaImg from '../assets/photos/reserva-pisaca.jpg';
---

<Layout title="Experiencias y Actividades" description="Descubre el Mirador Shiriculapo, senderismo andino y la Reserva Natural Pisaca cerca de Catacocha, Loja. Actividades turísticas desde Hostal Tambococha.">
    <section class="topography-bg relative flex min-h-[50vh] flex-col items-center justify-center bg-[#f8f7f6] pt-24 md:pt-32 pb-16 md:pb-20 px-4 md:px-6 text-center">
        <div class="max-w-3xl">
            <span class="mb-4 inline-block rounded-full bg-sage/10 px-4 py-1 text-xs font-bold uppercase tracking-widest text-sage">Descubre el Corazón de Loja</span>
            <h1 class="font-serif text-4xl md:text-5xl lg:text-7xl font-bold leading-tight text-earth">
                Experiencias en <span class="text-primary italic">Catacocha</span>
            </h1>
            <p class="mt-6 text-lg leading-relaxed text-earth/80 font-medium">
                Camina por increíbles senderos andinos, conecta con la belleza de nuestros miradores y respira la biodiversidad de reservas naturales únicas. Una invitación auténtica a explorar el patrimonio de nuestra zona.
            </p>
            <div class="mt-10 flex flex-wrap justify-center gap-4">
                <a class="flex items-center gap-2 rounded-lg bg-earth px-8 py-4 text-sm font-bold text-white hover:bg-earth/90 transition-all" href="#actividades">
                    Explorar Experiencias
                    <span class="material-symbols-outlined text-sm">expand_more</span>
                </a>
            </div>
        </div>
    </section>

    <div class="flex flex-col" id="actividades">
        <section class="bg-background-light py-12 md:py-20 px-4 md:px-6 lg:px-20">
            <div class="mx-auto max-w-7xl">
                <div class="flex flex-col overflow-hidden rounded-2xl bg-white shadow-xl shadow-earth/5 lg:flex-row">
                    <div class="relative aspect-video w-full lg:h-auto lg:w-1/2 overflow-hidden group">
                        <Image alt="Mirador del Shiriculapo" class="absolute inset-0 h-full w-full object-cover object-center transition-transform duration-700 group-hover:scale-110" src={miradorShiriculapoImg}/>
                    </div>
                    <div class="flex flex-col justify-center p-8 lg:p-16 lg:w-1/2">
                        <div class="mb-6 flex h-12 w-12 items-center justify-center rounded-full bg-sage text-white">
                            <span class="material-symbols-outlined">landscape</span>
                        </div>
                        <h3 class="font-serif text-2xl md:text-3xl font-bold text-background-dark">El Mirador del Shiriculapo</h3>
                        <p class="mt-4 text-earth/70 font-medium uppercase tracking-widest text-xs">Monumento Natural</p>
                        <p class="mt-6 text-lg leading-relaxed text-earth">
                            Conocido como el Balcón del Inca, este sitio sagrado ofrece panorámicas infinitas del horizonte lojano. Un punto energético vital que te conecta con la espiritualidad original de las civilizaciones locales.
                        </p>
                        <div class="mt-10">
                            <a href="https://www.youtube.com/watch?v=MaQarhy4rAg&t=385s" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 rounded-lg bg-primary px-6 py-3 text-sm font-bold text-white transition-all hover:translate-x-1 w-max">
                                Más Información
                                <span class="material-symbols-outlined text-sm">arrow_forward</span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="bg-background-dark py-12 md:py-20 px-4 md:px-6 lg:px-20">
            <div class="mx-auto max-w-7xl">
                <div class="flex flex-col overflow-hidden rounded-2xl bg-earth/10 border border-white/5 lg:flex-row-reverse">
                    <div class="relative aspect-video w-full lg:h-auto lg:w-1/2 overflow-hidden group">
                        <Image alt="Senderismo Andino" class="absolute inset-0 h-full w-full object-cover object-center transition-transform duration-700 group-hover:scale-110" src={catacochaSenderismoImg}/>
                    </div>
                    <div class="flex flex-col justify-center p-8 lg:p-16 lg:w-1/2">
                        <div class="mb-6 flex h-12 w-12 items-center justify-center rounded-full bg-sage text-white">
                            <span class="material-symbols-outlined">hiking</span>
                        </div>
                        <h3 class="font-serif text-2xl md:text-3xl font-bold text-white">Senderismo Andino</h3>
                        <p class="mt-4 text-primary font-medium uppercase tracking-widest text-xs">Excursión & Aventura</p>
                        <p class="mt-6 text-lg leading-relaxed text-background-light/70">
                            Explora rutas espectaculares que serpentean a través de la majestuosa cordillera de los Andes ecuatorianos. Compartimos rutas para distintos niveles de experiencia que desvelan paisajes únicos a cada paso.
                        </p>
                        <div class="mt-10">
                            <a href="https://es.wikiloc.com/rutas/senderismo/ecuador/loja/catacocha" target="_blank" class="flex items-center gap-2 rounded-lg bg-primary px-6 py-3 text-sm font-bold text-white transition-all hover:translate-x-1 w-max">
                                Más Información
                                <span class="material-symbols-outlined text-sm">arrow_forward</span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="bg-background-light py-12 md:py-20 px-4 md:px-6 lg:px-20">
            <div class="mx-auto max-w-7xl">
                <div class="flex flex-col overflow-hidden rounded-2xl bg-white shadow-xl shadow-earth/5 lg:flex-row">
                    <div class="relative aspect-video w-full lg:h-auto lg:w-1/2 overflow-hidden group">
                        <Image alt="Reserva Natural Pisaca" class="absolute inset-0 h-full w-full object-cover object-center transition-transform duration-700 group-hover:scale-110" src={reservaPisacaImg}/>
                    </div>
                    <div class="flex flex-col justify-center p-8 lg:p-16 lg:w-1/2">
                        <div class="mb-6 flex h-12 w-12 items-center justify-center rounded-full bg-sage text-white">
                            <span class="material-symbols-outlined">eco</span>
                        </div>
                        <h3 class="font-serif text-2xl md:text-3xl font-bold text-background-dark">Reserva Natural Pisaca</h3>
                        <p class="mt-4 text-earth/70 font-medium uppercase tracking-widest text-xs">Ecoturismo</p>
                        <p class="mt-6 text-lg leading-relaxed text-earth">
                            Un verdadero refugio de biodiversidad. Atrévete a descubrir ecosistemas endémicos propios del proyecto de recuperación hídrica, perfectos para la observación de aves, avistamiento de fauna andina y un encuentro íntimo con la flora de la región.
                        </p>
                        <div class="mt-10">
                            <a href="https://www.tiktok.com/@jessiviajando/video/7533452616941227320" target="_blank" class="flex items-center gap-2 rounded-lg bg-primary px-6 py-3 text-sm font-bold text-white transition-all hover:translate-x-1 w-max">
                                Más Información
                                <span class="material-symbols-outlined text-sm">arrow_forward</span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </div>
</Layout>

<style>
    .topography-bg {
        background-image: url("data:image/svg+xml,%3Csvg width='400' height='400' viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M0 380 Q 50 350 100 380 T 200 380 T 300 380 T 400 380 M0 340 Q 50 310 100 340 T 200 340 T 300 340 T 400 340 M0 300 Q 50 270 100 300 T 200 300 T 300 300 T 400 300 M0 260 Q 50 230 100 260 T 200 260 T 300 260 T 400 260' fill='none' stroke='%23d5840b' stroke-opacity='0.05' stroke-width='1'/%3E%3C/svg%3E");
    }
</style>
