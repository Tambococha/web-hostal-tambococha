---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contacto">
    <section class="bg-background-light pt-24 md:pt-32 pb-10 md:pb-16 px-4 md:px-6 border-b border-earth/10">
        <div class="max-w-7xl mx-auto text-center">
            <span class="mb-4 inline-block rounded-full bg-sage/10 px-4 py-1 text-xs font-bold uppercase tracking-widest text-sage">Atención al Cliente</span>
            <h1 class="font-serif text-4xl md:text-5xl lg:text-7xl font-bold leading-tight text-charcoal">Ponte en <span class="italic">Contacto</span></h1>
            <p class="mt-6 text-lg leading-relaxed text-earth/80 font-medium max-w-2xl mx-auto">
                Estamos aquí para hacer de su estadía una experiencia inolvidable en el corazón de Catacocha. Permítanos asistirle en cada detalle de su viaje.
            </p>
        </div>
    </section>

    <section class="max-w-7xl mx-auto px-4 md:px-6 py-12 pb-16 md:pb-24 flex flex-col lg:grid lg:grid-cols-2 gap-12 lg:gap-16 items-start">
        <div class="space-y-12 w-full">
            <div class="space-y-8">
                <div class="flex gap-6">
                    <div class="flex-shrink-0 w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center text-primary">
                        <span class="material-symbols-outlined">location_on</span>
                    </div>
                    <div>
                        <h3 class="font-serif text-xl font-bold mb-1">Dirección</h3>
                        <p class="text-earth leading-relaxed">25 de Junio y Lauro Guerrero, Catacocha, Loja, Ecuador</p>
                    </div>
                </div>
                <div class="flex gap-6">
                    <div class="flex-shrink-0 w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center text-primary">
                        <span class="material-symbols-outlined">call</span>
                    </div>
                    <div>
                        <h3 class="font-serif text-xl font-bold mb-1">Teléfono</h3>
                        <p class="text-earth leading-relaxed">Whatsapp: +593 9 8526 5183 // +593 9 9087 0767</p>
                    </div>
                </div>
                <div class="flex gap-6">
                    <div class="flex-shrink-0 w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center text-primary">
                        <span class="material-symbols-outlined">mail</span>
                    </div>
                    <div>
                        <h3 class="font-serif text-xl font-bold mb-1">Email</h3>
                        <p class="text-earth leading-relaxed">hoteltambococha@gmail.com</p>
                    </div>
                </div>
                <div class="flex gap-6">
                    <div class="flex-shrink-0 w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center text-primary">
                        <span class="material-symbols-outlined">schedule</span>
                    </div>
                    <div>
                        <h3 class="font-serif text-xl font-bold mb-1">Atención</h3>
                        <p class="text-earth leading-relaxed mb-2">24 horas, 7 días a la semana.</p>
                        <p class="text-earth leading-relaxed font-bold">Check-in: <span class="font-normal text-earth/80">14:00</span></p>
                        <p class="text-earth leading-relaxed font-bold">Check-out: <span class="font-normal text-earth/80">12:00</span></p>
                    </div>
                </div>
            </div>
            
            <div class="pt-8 border-t border-earth/10">
                <h4 class="font-serif text-lg font-bold mb-4">Síguenos en redes sociales</h4>
                <div class="flex flex-col sm:flex-row gap-4">
                    <a class="flex items-center gap-2 px-4 py-2 bg-white rounded-lg border border-earth/20 hover:border-primary hover:text-primary transition-all shadow-sm" href="https://www.facebook.com/hostaltambococha" target="_blank">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"></path></svg>
                        <span class="text-sm font-semibold">Facebook</span>
                    </a>
                    <a class="flex items-center gap-2 px-4 py-2 bg-white rounded-lg border border-earth/20 hover:border-primary hover:text-primary transition-all shadow-sm" href="https://www.instagram.com/hoteltambococha/" target="_blank">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.791-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.209-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"></path></svg>
                        <span class="text-sm font-semibold">Instagram</span>
                    </a>
                </div>
            </div>
        </div>

        <div class="relative">
            <div class="absolute -inset-4 bg-earth/5 rounded-2xl blur-2xl -z-10"></div>
            <div class="bg-white p-8 md:p-10 rounded-xl border border-earth/20 shadow-xl">
                <h2 class="font-serif text-2xl font-bold mb-8 text-charcoal">Formulario de Consultas</h2>
                <form action="https://api.web3forms.com/submit" method="POST" class="space-y-6">
                    <input type="hidden" name="access_key" value="c4c7a065-19f3-4dea-a2a1-9ff8ae6b095c">
                    <input type="hidden" name="subject" value="Nuevo Mensaje de Contacto - Sitio Web Tambococha">
                    <input type="checkbox" name="botcheck" class="hidden" style="display: none;">
                    <input type="hidden" name="redirect" value="https://web3forms.com/success">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="space-y-2">
                            <label class="text-xs font-bold uppercase tracking-wider text-earth/70" for="name">Nombre Completo</label>
                            <input class="w-full bg-background-light border-earth/10 rounded-lg focus:ring-primary focus:border-primary p-3 transition-all" id="name" name="nombre" placeholder="Su nombre aquí" type="text" required/>
                        </div>
                        <div class="space-y-2">
                            <label class="text-xs font-bold uppercase tracking-wider text-earth/70" for="email">Correo Electrónico</label>
                            <input class="w-full bg-background-light border-earth/10 rounded-lg focus:ring-primary focus:border-primary p-3 transition-all" id="email" name="email" placeholder="correo@ejemplo.com" type="email" required/>
                        </div>
                    </div>
                    <div class="space-y-2">
                        <label class="text-xs font-bold uppercase tracking-wider text-earth/70" for="subject">Asunto</label>
                        <input class="w-full bg-background-light border-earth/10 rounded-lg focus:ring-primary focus:border-primary p-3 transition-all" id="subject" name="asunto" placeholder="¿Cómo podemos ayudarle?" type="text" required/>
                    </div>
                    <div class="space-y-2">
                        <label class="text-xs font-bold uppercase tracking-wider text-earth/70" for="message">Mensaje</label>
                        <textarea class="w-full bg-background-light border-earth/10 rounded-lg focus:ring-primary focus:border-primary p-3 transition-all resize-none" id="message" name="mensaje" placeholder="Escriba su consulta detallada aquí..." rows="5" required></textarea>
                    </div>
                    <button class="w-full bg-primary hover:bg-primary/90 text-white font-bold py-4 px-8 rounded-lg transition-all transform active:scale-95 shadow-lg shadow-primary/20 flex items-center justify-center gap-2" type="submit">
                        <span>Enviar Mensaje</span>
                        <span class="material-symbols-outlined text-sm">send</span>
                    </button>
                </form>
            </div>
        </div>
    </section>
</Layout>
