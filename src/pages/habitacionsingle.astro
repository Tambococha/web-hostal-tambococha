---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import BookingScripts from '../components/BookingScripts.astro';
import ServiceBadge from '../components/ServiceBadge.astro';
import img01 from '../assets/photos/habitacion-simple-hostal-tambococha-01.jpg';
import img02 from '../assets/photos/habitacion-simple-hostal-tambococha-02.webp';
import img03 from '../assets/photos/habitacion-simple-hostal-tambococha-03.webp';
---

<Layout title="Habitación Simple | Hostal Tambococha" description="Habitación simple con baño privado, WiFi, Smart TV y estacionamiento en Catacocha. Ideal para viajeros. Desde $12/noche.">
    <BookingScripts slot="head" />
    <div class="max-w-7xl mx-auto px-4 md:px-6 py-8 md:py-12 pt-24 md:pt-32">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-start mb-16">
            <div class="lg:col-span-8 order-1">
                <div class="flex flex-col md:grid md:grid-cols-12 gap-4 h-auto md:h-[500px]">
                    <div class="md:col-span-8 h-72 md:h-full rounded-xl overflow-hidden group cursor-pointer gallery-trigger" data-index="0">
                        <Image alt="Habitación Simple Principal" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 gallery-img" src={img01}/>
                    </div>
                    <div class="md:col-span-4 flex flex-row md:flex-col gap-4 h-32 md:h-full shrink-0">
                        <div class="flex-1 rounded-xl overflow-hidden group cursor-pointer gallery-trigger relative" data-index="1">
                            <Image alt="Habitación Simple Secundaria 1" class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 gallery-img" src={img02}/>
                        </div>
                        <div class="flex-1 rounded-xl overflow-hidden group cursor-pointer gallery-trigger relative" data-index="2">
                            <Image alt="Habitación Simple Secundaria 2" class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 gallery-img" src={img03}/>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="lg:col-span-4 order-2 lg:row-span-2 mt-4 lg:mt-0 lg:sticky lg:top-28 relative z-10">
                <div class="bg-white rounded-xl shadow-2xl shadow-earth/10 border border-earth/5 p-6 md:p-8">
                    <div class="mb-8">
                        <p class="text-[10px] uppercase tracking-[0.2em] font-black text-sage mb-1">Precio por noche</p>
                        <div class="flex items-baseline gap-1">
                            <span class="text-4xl font-black text-earth">$12</span>
                            <span class="text-earth/60 font-medium font-serif line-through mr-2">usd/noche</span>
                            <span class="text-xl font-black text-primary ml-4">$15</span>
                            <span class="text-primary/60 font-medium text-xs font-serif uppercase">En Feriado</span>
                        </div>
                    </div>
                    
                    <form class="space-y-4 mb-8 text-left">
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-px bg-earth/10 border border-earth/10 rounded-lg overflow-hidden">
                            <div class="p-4 bg-background-light">
                                <label class="block text-[10px] font-black uppercase tracking-widest text-earth/50 mb-1">Check-in</label>
                                <input id="checkin" placeholder="Elegir..." class="bg-transparent border-none p-0 text-sm font-bold focus:ring-0 w-full text-earth outline-none cursor-pointer placeholder:font-normal placeholder:text-earth/40" type="text" readonly/>
                            </div>
                            <div class="p-4 bg-background-light">
                                <label class="block text-[10px] font-black uppercase tracking-widest text-earth/50 mb-1">Check-out</label>
                                <input id="checkout" placeholder="Elegir..." class="bg-transparent border-none p-0 text-sm font-bold focus:ring-0 w-full text-earth outline-none cursor-pointer placeholder:font-normal placeholder:text-earth/40" type="text" readonly/>
                            </div>
                        </div>
                        <div class="border border-earth/10 rounded-lg p-4 bg-background-light">
                            <label class="block text-[10px] font-black uppercase tracking-widest text-earth/50 mb-1">Tipo de Habitación</label>
                            <div class="flex flex-col sm:flex-row justify-between sm:items-center bg-transparent w-full">
                                <select onchange="window.location.href=this.value" class="bg-transparent border-none p-0 w-full outline-none text-sm font-bold text-earth cursor-pointer appearance-none break-words">
                                    <option value="/habitacionsingle" selected>Habitación Simple</option>
                                    <option value="/habitacionmatrimonial">Habitación Matrimonial</option>
                                    <option value="/habitaciondobletriple">Habitación Doble/Triple</option>
                                    <option value="/habitacionfamiliar">Habitación Familiar</option>
                                </select>
                            </div>
                        </div>
                        <div class="border border-earth/10 rounded-lg p-4 bg-background-light">
                            <label class="block text-[10px] font-black uppercase tracking-widest text-earth/50 mb-2">Adultos</label>
                            <div class="flex items-center gap-3">
                                <button
                                    id="btn-decrement"
                                    type="button"
                                    aria-label="Reducir adultos"
                                    class="w-10 h-10 flex-shrink-0 rounded-full bg-earth/5 border border-earth/10 text-primary flex items-center justify-center text-xl font-bold transition-all hover:bg-earth/10 hover:border-earth/20 active:scale-95 select-none"
                                >−</button>
                                <input
                                    id="huespedes"
                                    class="flex-1 bg-transparent border-none p-0 outline-none text-sm font-black text-earth text-center appearance-none [&::-webkit-inner-spin-button]:appearance-none [&::-webkit-outer-spin-button]:appearance-none [-moz-appearance:textfield]"
                                    type="number"
                                    min="1"
                                    max="1"
                                    value="1"
                                    readonly
                                />
                                <button
                                    id="btn-increment"
                                    type="button"
                                    aria-label="Aumentar adultos"
                                    class="w-10 h-10 flex-shrink-0 rounded-full bg-earth/5 border border-earth/10 text-primary flex items-center justify-center text-xl font-bold transition-all hover:bg-earth/10 hover:border-earth/20 active:scale-95 select-none"
                                >+</button>
                            </div>
                        </div>
                    </form>
                    
                    <button id="btn-pre-reserva" class="w-full bg-sage hover:bg-earth text-white font-bold py-5 rounded-lg transition-all flex items-center justify-center gap-3 uppercase tracking-widest text-xs">
                        <span id="btn-text">Confirmar Reserva</span>
                        <span class="material-symbols-outlined text-lg">calendar_today</span>
                    </button>
                    <p class="text-center text-[10px] text-earth/40 mt-6 uppercase tracking-widest font-bold">
                        Garantía de mejor precio online
                    </p>
                </div>
            </div>
            <div class="lg:col-span-8 order-3 mt-8 lg:mt-0">
                <div class="mb-12">
                    <div class="flex items-center gap-2 text-[10px] font-black uppercase tracking-[0.3em] text-primary mb-6">
                        <span class="w-8 h-[2px] bg-primary/30"></span>
                        Habitación Estándar
                    </div>
                    <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl font-black text-earth mb-6 md:mb-8">Habitación Simple</h1>
                    <div class="flex flex-col sm:flex-row flex-wrap gap-6 sm:gap-10 mb-8 md:mb-12">

                        <div class="flex flex-col gap-1">
                            <span class="text-[10px] uppercase tracking-widest font-black text-earth/40">Cama</span>
                            <div class="flex items-center gap-2 font-bold text-earth">
                                <span class="material-symbols-outlined text-primary text-xl">single_bed</span>
                                1 Plaza y media
                            </div>
                        </div>
                        <div class="flex flex-col gap-1">
                            <span class="text-[10px] uppercase tracking-widest font-black text-earth/40">Ocupación</span>
                            <div class="flex items-center gap-2 font-bold text-earth">
                                <span class="material-symbols-outlined text-primary text-xl">person</span>
                                1 Adulto
                            </div>
                        </div>
                    </div>
                    
                    <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 sm:gap-6 mt-4 mb-8 md:mb-12 p-4 bg-background-light rounded-xl border border-earth/5 sm:inline-flex inline-flex">
                        <div class="flex items-center gap-2">
                            <span class="material-symbols-outlined text-sage text-sm">schedule</span>
                            <span class="text-xs font-bold text-earth/70 uppercase tracking-widest">Check in: <span class="text-earth">14:00</span></span>
                        </div>
                        <div class="hidden sm:block w-px h-4 bg-earth/10"></div>
                        <div class="flex items-center gap-2">
                            <span class="material-symbols-outlined text-sage text-sm">event_available</span>
                            <span class="text-xs font-bold text-earth/70 uppercase tracking-widest">Check out: <span class="text-earth">12:00</span></span>
                        </div>
                    </div>
                    
                    <h2 class="font-serif text-2xl font-bold mb-6 md:mb-8 text-earth">Servicios Incluidos</h2>
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                        <ServiceBadge icon="wifi" text="Wifi de Alta Velocidad" />
                        <ServiceBadge icon="bathtub" text="Baño Privado" />
                        <ServiceBadge icon="hot_tub" text="Ducha Caliente" />
                        <ServiceBadge icon="concierge" text="Recepción" />
                        <ServiceBadge icon="smart_display" text="Smart TV" />
                        <ServiceBadge icon="air" text="Ventilador" />
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- MODAL DE RESUMEN -->
    <div id="booking-modal" class="fixed inset-0 z-[100] hidden items-center justify-center opacity-0 transition-opacity duration-300">
        <div id="modal-backdrop" class="absolute inset-0 bg-earth/80 backdrop-blur-sm cursor-pointer"></div>
        <div class="relative bg-white rounded-2xl p-6 md:p-8 w-[95%] md:max-w-md mx-auto shadow-2xl z-10 transform scale-95 transition-transform duration-300 max-h-[90vh] overflow-y-auto" id="modal-content">
            <button id="close-modal" class="absolute top-4 right-4 text-earth/40 hover:text-primary transition-colors" aria-label="Cerrar resumen de reserva">
                <span class="material-symbols-outlined text-3xl">close</span>
            </button>
            <div class="flex items-center gap-3 mb-6">
                <span class="material-symbols-outlined text-sage text-3xl">receipt_long</span>
                <h3 class="font-serif text-xl md:text-2xl font-bold text-earth">Resumen de Reserva</h3>
            </div>
            <div class="bg-background-light border border-earth/10 p-5 rounded-xl mb-6 space-y-3 text-sm">
                <div class="flex justify-between items-center"><span class="text-earth/60 font-bold uppercase text-[10px] tracking-widest">Habitación:</span> <span class="font-bold text-earth">Simple</span></div>
                <div class="flex justify-between items-center"><span class="text-earth/60 font-bold uppercase text-[10px] tracking-widest">Check-in:</span> <span class="font-bold text-earth" id="modal-in">-</span></div>
                <div class="flex justify-between items-center"><span class="text-earth/60 font-bold uppercase text-[10px] tracking-widest">Check-out:</span> <span class="font-bold text-earth" id="modal-out">-</span></div>
                <div class="flex justify-between items-center"><span class="text-earth/60 font-bold uppercase text-[10px] tracking-widest">Estadía:</span> <span class="font-bold text-earth bg-sage/10 text-sage px-2 py-1 rounded" id="modal-nights">0 noches</span></div>
                <div class="h-px w-full bg-earth/10 my-3"></div>
                <div class="flex justify-between items-end">
                    <span class="font-black text-earth text-lg">Total a pagar:</span> 
                    <div class="text-right">
                        <span class="font-black text-primary text-3xl font-serif" id="modal-total">$0</span>
                        <p class="text-[9px] text-earth/50 uppercase tracking-widest mt-1">*Pago en recepción</p>
                    </div>
                </div>
            </div>
            <div class="space-y-4 mb-4">
                <div>
                    <label class="block text-[10px] font-black uppercase tracking-widest text-earth/50 mb-1">Tu Nombre Completo *</label>
                    <input id="client-name" type="text" class="w-full bg-white border border-earth/20 rounded-lg p-3 text-sm font-bold text-earth focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" placeholder="Ej. Juan Pérez">
                </div>
                <div>
                    <label class="block text-[10px] font-black uppercase tracking-widest text-earth/50 mb-1">Tu Teléfono Móvil *</label>
                    <input id="client-phone" type="tel" class="w-full bg-white border border-earth/20 rounded-lg p-3 text-sm font-bold text-earth focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" placeholder="">
                </div>
            </div>

            <!-- Disclaimer de Tarifas Especiales -->
            <div class="flex gap-3 items-start rounded-xl border border-amber-200 bg-amber-50/60 p-4 mb-6">
                <span class="mt-0.5 shrink-0 text-amber-500">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/>
                    </svg>
                </span>
                <div class="flex flex-col gap-1">
                    <p class="text-[10px] font-black uppercase tracking-widest text-amber-700 leading-none">Aviso de Fechas Especiales</p>
                    <p class="text-[11px] text-amber-800/80 leading-relaxed font-medium">
                        Durante el 25 de junio y diciembre, las tarifas están sujetas a confirmación manual de la administración.
                    </p>
                </div>
            </div>

            <button id="btn-confirm-wa" class="w-full bg-[#25D366] hover:bg-[#128C7E] text-white font-bold py-4 rounded-lg transition-all flex items-center justify-center gap-3 uppercase tracking-widest text-xs shadow-lg shadow-[#25D366]/30">
                Confirmar por WhatsApp
            </button>
        </div>
    </div>

    <!-- Image Gallery Modal -->
    <div id="gallery-modal" class="fixed inset-0 z-[100] hidden items-center justify-center bg-earth/80 backdrop-blur-md opacity-0 transition-opacity duration-300">
        <button id="close-gallery" class="absolute top-4 right-4 md:top-8 md:right-8 text-white hover:text-primary bg-black/20 hover:bg-white rounded-full w-10 h-10 md:w-14 md:h-14 flex items-center justify-center transition-all z-[110]" aria-label="Cerrar galería">
            <span class="material-symbols-outlined text-xl md:text-3xl">close</span>
        </button>
        
        <button id="gallery-prev" class="absolute left-2 md:left-12 top-1/2 -translate-y-1/2 text-white hover:text-primary bg-black/20 hover:bg-white rounded-full w-10 h-10 md:w-16 md:h-16 flex items-center justify-center transition-all z-[110]" aria-label="Imagen anterior">
            <span class="material-symbols-outlined text-2xl md:text-5xl">chevron_left</span>
        </button>
        
        <button id="gallery-next" class="absolute right-2 md:right-12 top-1/2 -translate-y-1/2 text-white hover:text-primary bg-black/20 hover:bg-white rounded-full w-10 h-10 md:w-16 md:h-16 flex items-center justify-center transition-all z-[110]" aria-label="Imagen siguiente">
            <span class="material-symbols-outlined text-2xl md:text-5xl">chevron_right</span>
        </button>

        <div class="relative w-full max-w-6xl px-12 md:px-32 flex items-center justify-center z-[105] pointer-events-none">
            <img id="gallery-image-view" class="w-full aspect-[4/3] md:aspect-video object-cover rounded-xl shadow-[0_20px_60px_rgba(0,0,0,0.6)] scale-95 transition-transform duration-300 pointer-events-auto" src="" alt="Galería de fotos - Habitación Simple" />
        </div>
    </div>

    <script>
        import { initBookingLogic } from '../scripts/booking';

        initBookingLogic({
            precioNoche: 12,
            precioFeriado: 15,
            tipoHabitacion: "Habitación Simple"
        });

        const initGallery = () => {
            const triggers = document.querySelectorAll('.gallery-trigger');
            const modal = document.getElementById('gallery-modal');
            const imgView = document.getElementById('gallery-image-view') as HTMLImageElement;
            const btnClose = document.getElementById('close-gallery');
            const btnPrev = document.getElementById('gallery-prev');
            const btnNext = document.getElementById('gallery-next');
            
            if(!modal || !imgView || modal.dataset.initialized) return;
            modal.dataset.initialized = 'true';

            let images: string[] = [];
            let currentIndex = 0;

            triggers.forEach(trigger => {
                const img = trigger.querySelector('.gallery-img') as HTMLImageElement;
                if(img) {
                    // Si src no es ruta absoluta puede ser un proxy de Astro, lo agregaremos directo
                    images.push(img.src);
                    trigger.addEventListener('click', () => {
                        currentIndex = parseInt(trigger.getAttribute('data-index') || '0');
                        openGallery();
                    });
                }
            });

            function openGallery() {
                updateImage();
                modal!.classList.remove('hidden');
                modal!.classList.add('flex');
                setTimeout(() => {
                    modal!.classList.remove('opacity-0');
                    imgView!.classList.remove('scale-95');
                }, 10);
            }

            function closeGallery() {
                modal!.classList.add('opacity-0');
                imgView!.classList.add('scale-95');
                setTimeout(() => {
                    modal!.classList.add('hidden');
                    modal!.classList.remove('flex');
                }, 300);
            }

            function updateImage() {
                if (images.length > 0) {
                    imgView.src = images[currentIndex];
                }
            }

            function nextImage() {
                currentIndex = (currentIndex + 1) % images.length;
                updateImage();
            }

            function prevImage() {
                currentIndex = (currentIndex - 1 + images.length) % images.length;
                updateImage();
            }

            btnClose?.addEventListener('click', closeGallery);
            btnNext?.addEventListener('click', nextImage);
            btnPrev?.addEventListener('click', prevImage);
            
            modal!.addEventListener('click', (e) => {
                if (e.target === modal) closeGallery();
            });

            document.addEventListener('keydown', (e) => {
                if (!modal!.classList.contains('hidden')) {
                    if (e.key === 'Escape') closeGallery();
                    if (e.key === 'ArrowRight') nextImage();
                    if (e.key === 'ArrowLeft') prevImage();
                }
            });
        };

        initGallery();
    </script>
</Layout>
