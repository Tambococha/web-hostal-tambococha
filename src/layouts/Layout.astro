---
import NavBar from '../components/NavBar.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';

interface Props {
	title?: string;
	description?: string;
	image?: string;
}

const { 
	title, 
	description = "Alojamiento en Catacocha. Hotel Tambococha es tu refugio ideal en el centro histórico de Loja, Ecuador.", 
	image = "/og-image.jpg" 
} = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title ? `${title} | Hotel Tambococha` : 'Hotel Tambococha | Alojamiento en Catacocha, Loja, Ecuador'}</title>
		<meta name="description" content={description} />
		
		<!-- Open Graph / SEO -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={Astro.url} />
		<meta property="og:title" content={title ? `${title} | Hotel Tambococha` : 'Hotel Tambococha | Alojamiento en Catacocha, Loja, Ecuador'} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={image} />
		<meta property="og:locale" content="es_EC" />
		
		<!-- Schema Markup (JSON-LD) -->
		<script type="application/ld+json">
			{
				"@context": "https://schema.org",
				"@type": "Hotel",
				"name": "Hotel Tambococha",
				"address": {
					"@type": "PostalAddress",
					"streetAddress": "25 de Junio y Lauro Guerrero (Frente a la Iglesia Matriz)",
					"addressLocality": "Catacocha",
					"addressRegion": "Loja",
					"addressCountry": "Ecuador"
				},
				"telephone": "+593985265183",
				"url": "https://hoteltambococha.com",
				"priceRange": "$",
				"geo": {
					"@type": "GeoCoordinates",
					"latitude": -4.049952,
					"longitude": -79.651140
				}
			}
		</script>

		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;500;600;700;800&family=Manrope:wght@300;400;500;600;700;800&display=swap" rel="stylesheet"/>
		<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
		
		<!-- Flatpickr (Calendario) -->
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
		<script is:inline src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
		<script is:inline src="https://npmcdn.com/flatpickr/dist/l10n/es.js"></script>
		
		<!-- intl-tel-input (Teléfono) -->
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/intl-tel-input@23.0.4/build/css/intlTelInput.css">
		<script is:inline src="https://cdn.jsdelivr.net/npm/intl-tel-input@23.0.4/build/js/intlTelInput.min.js"></script>
		<style is:global>
			.iti { width: 100%; }
			.iti__country-list { z-index: 105; }
			.iti__search-input { outline: none; }
		</style>
	</head>
	<body class="bg-background-light text-earth selection:bg-primary/30 min-h-screen flex flex-col">
		<NavBar />
		<main class="flex-grow">
			<slot />
		</main>
		<Footer />
		<WhatsAppButton />
	</body>
</html>

<style is:global>
	html {
		scroll-behavior: smooth;
	}
	.glass-nav {
		background: rgba(248, 247, 246, 0.9);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
	}
</style>
