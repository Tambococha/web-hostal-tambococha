---
import NavBar from '../components/NavBar.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';

interface Props {
	title?: string;
	description?: string;
	image?: string;
}

const { 
	title, 
	description = "Alojamiento en el corazón de Paltas. Hostal Tambococha es tu refugio de tradición y calma en Catacocha, Loja, Ecuador.", 
	image = "/og-image.jpg" 
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<link rel="canonical" href={canonicalURL} />
		<meta name="generator" content={Astro.generator} />
		<title>{title ? `${title} | Hostal Tambococha` : 'Hostal Tambococha | Alojamiento en el Corazón de Paltas, Ecuador'}</title>
		<meta name="description" content={description} />
		
		<!-- Open Graph / SEO -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={Astro.url} />
		<meta property="og:title" content={title ? `${title} | Hostal Tambococha` : 'Hostal Tambococha | Alojamiento en el Corazón de Paltas, Ecuador'} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={image} />
		<meta property="og:locale" content="es_EC" />
		
		<!-- Schema Markup (JSON-LD) -->
		<script type="application/ld+json">
			{
				"@context": "https://schema.org",
				"@type": ["Hotel", "LodgingBusiness", "Hostel"],
				"name": "Hostal Tambococha",
				"description": "Tu opción preferida de hotel, hostal y alojamiento en Catacocha, Loja.",
				"keywords": "Hotel, Accommodation, Hostal, Alojamiento, Catacocha",
				"address": {
					"@type": "PostalAddress",
					"streetAddress": "25 de Junio y Lauro Guerrero (Frente a la Iglesia Matriz)",
					"addressLocality": "Catacocha",
					"addressRegion": "Loja",
					"addressCountry": "Ecuador"
				},
				"telephone": "+593985265183",
				"url": "https://hoteltambococha.com",
				"priceRange": "$",
				"geo": {
					"@type": "GeoCoordinates",
					"latitude": -4.049952,
					"longitude": -79.651140
				}
			}
		</script>

		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;500;600;700;800&family=Manrope:wght@300;400;500;600;700;800&display=swap" rel="stylesheet"/>
		<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
		
		<slot name="head" />
	</head>
	<body class="bg-background-light text-earth selection:bg-primary/30 min-h-screen flex flex-col">
		<NavBar />
		<main class="flex-grow">
			<slot />
		</main>
		<Footer />
		<WhatsAppButton />
	</body>
</html>

<style is:global>
	html {
		scroll-behavior: smooth;
	}
	.glass-nav {
		background: rgba(248, 247, 246, 0.9);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
	}
</style>
